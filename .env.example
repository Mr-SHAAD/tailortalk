# ── LLM API (use any one) ──────────────────────────────────────────────────
# Option 1: Groq (FREE — recommended for beginners)

# Option 2: OpenAI (paid)
# OPENAI_API_KEY=your_openai_api_key_here

# ── Which LLM to use: "groq" or "openai" ──────────────────────────────────


# ── Google Drive ───────────────────────────────────────────────────────────
# Path to your service account JSON key file


# The Google Drive FOLDER ID to search in
# (from the sample folder URL: https://drive.google.com/drive/folders/FOLDER_ID)


# ── FastAPI Backend URL (for Streamlit to call) ────────────────────────────
BACKEND_URL=http://localhost:8000
GROQ_API_KEY=GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_DRIVE_FOLDER_ID=key_folder_id_here
BACKEND_URL=http://localhost:8000